<?xml version="1.0" encoding="utf-8"?>
<com.teamclouday.androidsteering.view.DraggableFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/draggable_root_alt"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <!-- LEFTMOST COLUMN (LB/LT) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLB"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:text="@string/buttonLB"
            app:layout_constraintBottom_toTopOf="@+id/buttonLT"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLT"
            android:layout_width="80dp"
            android:layout_height="200dp"
            android:text="@string/buttonLT"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBarLT"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- MIDDLE-LEFT COLUMN (Y/X) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonY"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="Y"
            android:textColor="#FFEB3B"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toTopOf="@+id/buttonX"
            app:layout_constraintStart_toEndOf="@+id/buttonLT"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonX"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="X"
            android:textColor="#2196F3"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/buttonLT"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="16dp" />

        <!-- MIDDLE-RIGHT COLUMN (A/B) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonB"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="B"
            android:textColor="#F44336"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toTopOf="@+id/buttonA"
            app:layout_constraintEnd_toStartOf="@+id/buttonRT"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonA"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="A"
            android:textColor="#8BC34A"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buttonRT"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="16dp" />

        <!-- RIGHTMOST COLUMN (RB/RT) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRB"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:text="@string/buttonRB"
            app:layout_constraintBottom_toTopOf="@+id/buttonRT"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRT"
            android:layout_width="80dp"
            android:layout_height="200dp"
            android:text="@string/buttonRT"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBarRT"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sensor Switch & Crosshair -->
        <com.teamclouday.androidsteering.view.SensorCrosshairView
            android:id="@+id/sensorCrosshair"
            android:layout_width="98dp"
            android:layout_height="98dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_sensor_pitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll Sensor"
            android:textColor="@color/btn_overlay_text"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:checked="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.teamclouday.androidsteering.view.DraggableFrameLayout>