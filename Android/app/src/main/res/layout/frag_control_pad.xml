<?xml version="1.0" encoding="utf-8"?>
<com.teamclouday.androidsteering.view.DraggableFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/draggable_root_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLT"
            android:layout_width="80dp"
            android:layout_height="200dp"
            android:text="@string/buttonLT"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRT"
            android:layout_width="80dp"
            android:layout_height="200dp"
            android:text="@string/buttonRT"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buttonLB"
            app:layout_constraintStart_toEndOf="@+id/buttonLT"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buttonRB"
            app:layout_constraintEnd_toStartOf="@+id/buttonRT"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBACK"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buttonBACK"
            app:layout_constraintEnd_toStartOf="@+id/buttonSTART"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSTART"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buttonSTART"
            app:layout_constraintEnd_toStartOf="@+id/buttonHOME"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonHOME"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buttonHOME"
            app:layout_constraintEnd_toStartOf="@+id/buttonRB"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="16dp" />

        <!-- DPAD -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonUP"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="▲"
            android:textColor="#FFFFFF"
            app:backgroundTint="#333333"
            app:layout_constraintBottom_toTopOf="@+id/buttonDOWN"
            app:layout_constraintEnd_toEndOf="@+id/buttonDOWN"
            app:layout_constraintStart_toStartOf="@+id/buttonDOWN"
            android:layout_marginBottom="56dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLEFT"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="◀"
            android:textColor="#FFFFFF"
            app:backgroundTint="#333333"
            app:layout_constraintBottom_toBottomOf="@+id/buttonDOWN"
            app:layout_constraintEnd_toStartOf="@+id/buttonDOWN"
            app:layout_constraintTop_toTopOf="@+id/buttonUP" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDOWN"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="▼"
            android:textColor="#FFFFFF"
            app:backgroundTint="#333333"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/buttonLT"
            android:layout_marginStart="80dp"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRIGHT"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="▶"
            android:textColor="#FFFFFF"
            app:backgroundTint="#333333"
            app:layout_constraintBottom_toBottomOf="@+id/buttonDOWN"
            app:layout_constraintStart_toEndOf="@+id/buttonDOWN"
            app:layout_constraintTop_toTopOf="@+id/buttonUP" />

        <!-- ABXY -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonY"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="Y"
            android:textColor="#FFEB3B"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toTopOf="@+id/buttonA"
            app:layout_constraintEnd_toEndOf="@+id/buttonA"
            app:layout_constraintStart_toStartOf="@+id/buttonA"
            android:layout_marginBottom="56dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonX"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="X"
            android:textColor="#2196F3"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toBottomOf="@+id/buttonA"
            app:layout_constraintEnd_toStartOf="@+id/buttonA"
            app:layout_constraintTop_toTopOf="@+id/buttonY" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonA"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="A"
            android:textColor="#8BC34A"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buttonRT"
            android:layout_marginEnd="80dp"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonB"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="B"
            android:textColor="#F44336"
            app:backgroundTint="@color/btn_overlay_bg"
            app:layout_constraintBottom_toBottomOf="@+id/buttonA"
            app:layout_constraintStart_toEndOf="@+id/buttonA"
            app:layout_constraintTop_toTopOf="@+id/buttonY" />

        <ProgressBar
            android:id="@+id/progressBarLT"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ProgressBar
            android:id="@+id/progressBarRT"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <io.github.controlwear.virtual.joystick.android.JoystickView
            android:id="@+id/joystickLeft"
            android:layout_width="125dp"
            android:layout_height="125dp"
            app:JV_backgroundColor="@color/joystickBackground"
            app:JV_borderColor="@color/joystickBorder"
            app:JV_borderWidth="4dp"
            app:JV_buttonColor="@color/joystickButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/buttonLT"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginTop="32dp" />

        <io.github.controlwear.virtual.joystick.android.JoystickView
            android:id="@+id/joystickRight"
            android:layout_width="125dp"
            android:layout_height="125dp"
            app:JV_backgroundColor="@color/joystickBackground"
            app:JV_borderColor="@color/joystickBorder"
            app:JV_borderWidth="4dp"
            app:JV_buttonColor="@color/joystickButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buttonRT"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="32dp" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</com.teamclouday.androidsteering.view.DraggableFrameLayout>